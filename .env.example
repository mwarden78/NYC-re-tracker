# =============================================================================
# NYC RE Tracker - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env with real secrets.
# =============================================================================

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key

# Linear (for ticket management tooling)
LINEAR_API_KEY=lin_api_xxxxx

# Optional: Mapbox token for enhanced map tiles
# MAPBOX_TOKEN=pk.xxxxx

# Optional: NYC Open Data app token (higher rate limits for ingestion script)
# Register free at https://data.cityofnewyork.us/profile/app_tokens
# NYC_OPEN_DATA_APP_TOKEN=your-app-token

# Optional: Walk Score API key (for Walk/Transit/Bike score enrichment)
# Register free at https://www.walkscore.com/professional/api.php (5,000 calls/day)
# WALKSCORE_API_KEY=your-walk-score-api-key
