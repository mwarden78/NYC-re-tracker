# Copy this file to .streamlit/secrets.toml for local dev (gitignored).
# In Streamlit Community Cloud, set these under App Settings > Secrets.

SUPABASE_URL = "https://your-project.supabase.co"
SUPABASE_KEY = "your-anon-key"

# Optional: higher rate limits for NYC Open Data ingestion
# NYC_OPEN_DATA_APP_TOKEN = "your-app-token"
